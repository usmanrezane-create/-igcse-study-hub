OPENAI_API_KEY=put_your_secret_api_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1
APP_NAME=My AI Studio
APP_TAGLINE=Chat, create, edit and work with files
PORT=3000

# Practical limits you control. Hosting and API limits still apply.
MAX_FILE_MB=25
MAX_FILES=8
CHAT_REQUESTS_PER_MINUTE=20
MEDIA_REQUESTS_PER_MINUTE=8
MAX_OUTPUT_TOKENS=1800
PDF_DETAIL=high

# Optional features
ENABLE_WEB_SEARCH=true
ENABLE_MODERATION=true
